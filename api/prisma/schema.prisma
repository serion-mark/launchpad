generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?   // null for social login
  name          String?
  avatar        String?
  provider      String    @default("email") // email, google, kakao, naver, apple
  providerId    String?
  plan          String    @default("free") // free, starter, pro
  planPrice     Int       @default(0)     // 월 가격 (원)
  planExpiresAt DateTime?
  planStatus    String    @default("ACTIVE") // ACTIVE, SUSPENDED, CANCELLED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[]
  invoices      Invoice[]
  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  template    String   // beauty-salon, booking-crm, ecommerce
  theme       String   @default("basic-light")
  features    Json?    // selected features
  status      String   @default("draft") // draft, generating, active, deployed
  subdomain   String?  @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  chatHistory Json?    // builder chat messages
  generatedCode Json?  // generated file paths
  deployedUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model Invoice {
  id             String   @id @default(cuid())
  userId         String
  month          String                          // "2026-03"
  plan           String                          // free, starter, pro
  amount         Int                             // 청구 금액 (원)
  status         String   @default("PENDING")    // PENDING, PAID, FAILED, CANCELLED
  dueDate        DateTime
  paidAt         DateTime?
  paidAmount     Int?
  paymentMethod  String?
  paymentRefId   String?
  memo           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, month])
  @@index([status, dueDate])
  @@map("invoices")
}

model PaymentEvent {
  id             String   @id @default(cuid())
  userId         String
  invoiceId      String?
  eventType      String                          // PLAN_CHANGE, PAYMENT_SUCCESS, PAYMENT_FAILED, REFUND
  amount         Int      @default(0)
  description    String?
  processedAt    DateTime @default(now())

  @@index([userId, processedAt])
  @@map("payment_events")
}
