generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?   // null for social login
  name          String?
  avatar        String?
  provider      String    @default("email") // email, google, kakao, naver, apple
  providerId    String?
  plan          String    @default("free") // free, starter, pro
  planPrice     Int       @default(0)     // 월 가격 (원)
  planExpiresAt DateTime?
  planStatus    String    @default("ACTIVE") // ACTIVE, SUSPENDED, CANCELLED
  // ── 약관 동의 ──
  termsAgreedAt     DateTime?  // 이용약관 동의 일시
  privacyAgreedAt   DateTime?  // 개인정보처리방침 동의 일시
  refundAgreedAt    DateTime?  // 환불정책+소유권 동의 일시
  marketingAgreedAt DateTime?  // 마케팅 수신 동의 일시 (선택)
  // ── GitHub 연동 ──
  githubToken   String?   // GitHub OAuth access token (repo push용)
  // ── 사업자 정보 (정부지원사업 정산용) ──
  company            String?   // 회사명/상호
  businessName       String?   // 사업자 상호 (정산용)
  businessNumber     String?   // 사업자등록번호
  representative     String?   // 대표자명
  businessAddress    String?   // 사업장 주소
  businessPhone      String?   // 사업장 전화번호
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[]
  invoices      Invoice[]
  creditBalance CreditBalance?
  memory        UserMemory?
  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  template    String   // beauty-salon, booking-crm, ecommerce
  theme       String   @default("basic-light")
  features    Json?    // selected features
  status      String   @default("draft") // draft, generating, active, deployed
  subdomain   String?  @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  chatHistory Json?    // builder chat messages
  generatedCode Json?  // generated file paths/code
  deployedUrl String?
  // ── 코드 생성 엔진 필드 (Sprint 1) ──
  projectContext     Json?              // 자동 저장 컨텍스트 {completedFeatures, pendingFeatures, lastAction, userPreferences, conversationSummary}
  versions           Json?              // [{version, snapshot, createdAt, description}]
  currentVersion     Int     @default(1)
  healthScore        Int?               // 0~100 코드 건강도
  totalModifications Int     @default(0)
  modelUsed          String?            // 마지막 사용 모델 tier (flash/smart/pro)
  // ── Supabase 자동 프로비저닝 ──
  supabaseProjectRef String?            // Supabase project reference (e.g., "abcdefghijkl")
  supabaseUrl        String?            // https://xxx.supabase.co
  supabaseAnonKey    String?            // 공개 anon key
  supabaseServiceKey String?            // service_role key (서버용)
  supabaseDbPass     String?            // DB 비밀번호 (생성 시 저장)
  supabaseStatus     String?            // creating | active | failed
  // ── 배포 파이프라인 ──
  buildStatus        String?            // pending | building | exporting | done | failed
  buildLog           String?            // 빌드 로그 (에러 디버깅용)
  buildStartedAt     DateTime?
  buildFinishedAt    DateTime?
  // ── GitHub 연동 ──
  githubRepoUrl      String?            // https://github.com/user/repo
  // ── 호스팅 과금 (MRR) ──
  hostingPlan        String   @default("free")  // free | basic | pro
  hostingExpiresAt   DateTime?
  monthlyVisitors    Int      @default(0)       // 이번 달 방문자 수
  visitorResetAt     DateTime?                  // 방문자 카운트 리셋 시점
  // 24시간 체험: projectContext.trialExpiresAt / projectContext.trialDeployed 사용
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memory        ProjectMemory?
  @@map("projects")
}

model Invoice {
  id             String   @id @default(cuid())
  userId         String
  month          String                          // "2026-03"
  plan           String                          // free, starter, pro
  amount         Int                             // 청구 금액 (원)
  status         String   @default("PENDING")    // PENDING, PAID, FAILED, CANCELLED
  dueDate        DateTime
  paidAt         DateTime?
  paidAmount     Int?
  paymentMethod  String?
  paymentRefId   String?
  memo           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, month])
  @@index([status, dueDate])
  @@map("invoices")
}

model PaymentEvent {
  id             String   @id @default(cuid())
  userId         String
  invoiceId      String?
  eventType      String                          // PLAN_CHANGE, PAYMENT_SUCCESS, PAYMENT_FAILED, REFUND
  amount         Int      @default(0)
  description    String?
  processedAt    DateTime @default(now())

  @@index([userId, processedAt])
  @@map("payment_events")
}

// ── 크레딧 시스템 ────────────────────────────────────
model CreditBalance {
  id             String   @id @default(cuid())
  userId         String   @unique
  balance        Int      @default(0)            // 현재 잔액
  totalCharged   Int      @default(0)            // 누적 충전
  totalUsed      Int      @default(0)            // 누적 사용
  freeTrialUsed  Boolean  @default(false)        // 맛보기 설계안 사용 여부
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
  transactions   CreditTransaction[]

  @@map("credit_balances")
}

model CreditTransaction {
  id             String   @id @default(cuid())
  userId         String
  balanceId      String
  type           String                          // CHARGE, USE, REFUND, FREE_TRIAL, SIGNUP_BONUS
  amount         Int                             // 양수=충전, 음수=차감
  balanceAfter   Int                             // 트랜잭션 후 잔액
  description    String?                         // "라이트팩 구매", "앱 생성: 미용실 POS" 등
  projectId      String?                         // 사용 시 프로젝트 연결
  taskType       String?                         // architecture, frontend, backend, schema, modify, chat
  modelTier      String?                         // fast, standard, premium
  paymentRefId   String?                         // 토스 결제 참조 ID
  createdAt      DateTime @default(now())

  balance        CreditBalance @relation(fields: [balanceId], references: [id])

  @@index([userId, createdAt])
  @@index([type])
  @@map("credit_transactions")
}

// ── 프로젝트 메모리 (AI 대화 컨텍스트 유지) ──────────
model ProjectMemory {
  id            String   @id @default(cuid())
  projectId     String   @unique
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chatSummary   String?  // Haiku가 매 대화 후 자동 요약
  preferences   Json?    // 사용자 선호 자동 학습 {style, priority, colors, fonts}
  modHistory    Json?    // 수정 히스토리 [{version, change, date}]
  updatedAt     DateTime @updatedAt

  @@map("project_memories")
}

// ── 사용자 메모리 (프로젝트 공통 선호) ────────────────
model UserMemory {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  designPref    Json?    // 색상/폰트/레이아웃 선호 (모든 프로젝트 공통)
  domain        String?  // 업종/분야 ("반려동물", "교육" 등)
  updatedAt     DateTime @updatedAt

  @@map("user_memories")
}
