generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?   // null for social login
  name          String?
  avatar        String?
  provider      String    @default("email") // email, google, kakao, naver, apple
  providerId    String?
  plan          String    @default("free") // free, starter, pro
  planPrice     Int       @default(0)     // 월 가격 (원)
  planExpiresAt DateTime?
  planStatus    String    @default("ACTIVE") // ACTIVE, SUSPENDED, CANCELLED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[]
  invoices      Invoice[]
  creditBalance CreditBalance?
  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  template    String   // beauty-salon, booking-crm, ecommerce
  theme       String   @default("basic-light")
  features    Json?    // selected features
  status      String   @default("draft") // draft, generating, active, deployed
  subdomain   String?  @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  chatHistory Json?    // builder chat messages
  generatedCode Json?  // generated file paths/code
  deployedUrl String?
  // ── 코드 생성 엔진 필드 (Sprint 1) ──
  projectContext     Json?              // 자동 저장 컨텍스트 {completedFeatures, pendingFeatures, lastAction, userPreferences, conversationSummary}
  versions           Json?              // [{version, snapshot, createdAt, description}]
  currentVersion     Int     @default(1)
  healthScore        Int?               // 0~100 코드 건강도
  totalModifications Int     @default(0)
  modelUsed          String?            // 마지막 사용 모델 tier (flash/smart/pro)
  // ── Supabase 자동 프로비저닝 ──
  supabaseProjectRef String?            // Supabase project reference (e.g., "abcdefghijkl")
  supabaseUrl        String?            // https://xxx.supabase.co
  supabaseAnonKey    String?            // 공개 anon key
  supabaseServiceKey String?            // service_role key (서버용)
  supabaseDbPass     String?            // DB 비밀번호 (생성 시 저장)
  supabaseStatus     String?            // creating | active | failed
  // ── 배포 파이프라인 ──
  buildStatus        String?            // pending | building | exporting | done | failed
  buildLog           String?            // 빌드 로그 (에러 디버깅용)
  buildStartedAt     DateTime?
  buildFinishedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model Invoice {
  id             String   @id @default(cuid())
  userId         String
  month          String                          // "2026-03"
  plan           String                          // free, starter, pro
  amount         Int                             // 청구 금액 (원)
  status         String   @default("PENDING")    // PENDING, PAID, FAILED, CANCELLED
  dueDate        DateTime
  paidAt         DateTime?
  paidAmount     Int?
  paymentMethod  String?
  paymentRefId   String?
  memo           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, month])
  @@index([status, dueDate])
  @@map("invoices")
}

model PaymentEvent {
  id             String   @id @default(cuid())
  userId         String
  invoiceId      String?
  eventType      String                          // PLAN_CHANGE, PAYMENT_SUCCESS, PAYMENT_FAILED, REFUND
  amount         Int      @default(0)
  description    String?
  processedAt    DateTime @default(now())

  @@index([userId, processedAt])
  @@map("payment_events")
}

// ── 크레딧 시스템 ────────────────────────────────────
model CreditBalance {
  id             String   @id @default(cuid())
  userId         String   @unique
  balance        Int      @default(0)            // 현재 잔액
  totalCharged   Int      @default(0)            // 누적 충전
  totalUsed      Int      @default(0)            // 누적 사용
  freeTrialUsed  Boolean  @default(false)        // 맛보기 설계안 사용 여부
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
  transactions   CreditTransaction[]

  @@map("credit_balances")
}

model CreditTransaction {
  id             String   @id @default(cuid())
  userId         String
  balanceId      String
  type           String                          // CHARGE, USE, REFUND, FREE_TRIAL, SIGNUP_BONUS
  amount         Int                             // 양수=충전, 음수=차감
  balanceAfter   Int                             // 트랜잭션 후 잔액
  description    String?                         // "라이트팩 구매", "앱 생성: 미용실 POS" 등
  projectId      String?                         // 사용 시 프로젝트 연결
  taskType       String?                         // architecture, frontend, backend, schema, modify, chat
  modelTier      String?                         // fast, standard, premium
  paymentRefId   String?                         // 토스 결제 참조 ID
  createdAt      DateTime @default(now())

  balance        CreditBalance @relation(fields: [balanceId], references: [id])

  @@index([userId, createdAt])
  @@index([type])
  @@map("credit_transactions")
}
